## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Visual Studio cache/options directory
.vs/

# Rider
.idea/

# VS Code
.vscode/

# Logs
*.log

# NuGet
*.nupkg
*.snupkg
# Packages folder
**/[Pp]ackages/*
# Except build/
!**/[Pp]ackages/build/

# NuGet v3's project.json files produces more ignoreable files
*.nuget.props
*.nuget.targets

# Microsoft Azure Web App publish settings
*.PublishSettings

# IIS Express
.vs/
IISExpress/
*.iisExpress.config

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Mac
.DS_Store

# Coverage results
coverage/
*.coverage
*.coveragexml

# Test results
TestResults/

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# DotCover
*.dotCover

# NCrunch
*.ncrunch*
.*crunch*.local.xml

# StyleCop
StyleCopReport.xml

# Backup & report files
*.bak
*.backup
*.tmp
*.temp

# Generated files
Generated\ Files/

# Entity Framework Migrations (optional – remove if you want them tracked)
# Migrations/

# Publish output
publish/

# Azure Functions
bin/
obj/
.tmp-build/

# Local environment files
.env
.env.*

# JetBrains Rider
*.sln.iml

CLAUDE.md
CURSOR.md
PLAN.md